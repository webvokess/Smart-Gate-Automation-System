# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Replace with your Atlas URI or use local below
# Atlas format: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/sgas?retryWrites=true&w=majority
# Local format:
MONGODB_URI=mongodb+srv://sgasuser:yourpassword123@cluster0.2ccwjyf.mongodb.net/sgas?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=sgas_super_secret_key_for_deendayal_port_2026_iit_madras
